# Service-local env. Mirrors the top-level axia/.env; only used for
# `make service-dev` (running the service on the host).

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=axia
MONGODB_CORPUS_COLLECTION=sources
MONGODB_METADATA_COLLECTION=metadata_records

MODEL_SERVER_URL=

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5-mini

SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_LOG_LEVEL=info
SERVICE_DEBUG=false
