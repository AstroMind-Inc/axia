# Fine-tuned model server configuration.
# Copy to .env and adjust paths to match your checkpoint layout.

# Base model identifier on Hugging Face (downloaded into MODEL_CACHE_DIR).
BASE_MODEL_NAME=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B

# Path to the LoRA adapter directory produced by training (also contains tokenizer).
ADAPTER_DIR=/workspace/qwen-7b/final_model_7B-9-epochs

# Path to the joblib bundle containing the fitted PCA + UMAP transformers.
UMAP_PCA_BUNDLE=/workspace/qwen-7b/final_model_7B-9-epochs/pca_umap/xray_umap_pca_bundle.joblib

# HF cache directory (large; mount a volume here).
MODEL_CACHE_DIR=/workspace/cache

# Server settings
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# Optional Hugging Face token (only needed if your base model is gated)
# HF_TOKEN=hf_xxx
