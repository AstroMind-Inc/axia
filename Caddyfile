{$DOMAIN:localhost} {
	reverse_proxy webapp:3000

	handle_path /api/service/* {
		reverse_proxy service:8000
	}

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 3
		}
	}
}
