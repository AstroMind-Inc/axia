# =============================================================================
# Axia — environment configuration
# Copy this file to .env and edit. `make setup` will write it interactively.
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB
# MONGODB_MODE=local   -> docker-compose starts a Mongo 7 container and seeds
#                         it with data/samples on first boot.
# MONGODB_MODE=external -> use the URI below (e.g. Atlas), no container is run.
# -----------------------------------------------------------------------------
MONGODB_MODE=local
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=axia

# Collections (don't change unless you know why). The corpus collection
# carries one merged doc per source — both event_lists (pruned + original),
# pca_64d, umap_2d, ra/dec, and every CSC catalog field — see docs/07_dataset.md.
MONGODB_CORPUS_COLLECTION=sources
MONGODB_METADATA_COLLECTION=metadata_records

# -----------------------------------------------------------------------------
# Fine-tuned model server (OPTIONAL)
# Set this to the URL where you run model/server (e.g. RunPod/vast.ai/local GPU).
# Leave EMPTY to disable the Event Analyst path; everything else still works.
# -----------------------------------------------------------------------------
MODEL_SERVER_URL=

# -----------------------------------------------------------------------------
# OpenAI (required for GPT-5 agents: Metadata, Neighbor, Critic, Tool, Moderator)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5-mini

# -----------------------------------------------------------------------------
# Service (FastAPI orchestrator)
# -----------------------------------------------------------------------------
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_LOG_LEVEL=info
SERVICE_DEBUG=false

# -----------------------------------------------------------------------------
# Webapp (Next.js)
# Two-tier URL:
#   SERVICE_URL          : used by the webapp's server-side API routes (in
#                          docker this is the in-network hostname).
#   NEXT_PUBLIC_API_URL  : baked into the browser bundle (so the user's
#                          browser must be able to reach this URL).
# -----------------------------------------------------------------------------
SERVICE_URL=http://service:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MONGODB_URI=mongodb://localhost:27017
NEXT_PUBLIC_MONGODB_DB=axia
NEXT_PUBLIC_MONGODB_MODE=local
NEXT_PUBLIC_ALLOWED_FILE_TYPES=.json,.pkl
NEXT_PUBLIC_DEBUG=false

# Host port to expose the webapp on (container always listens on 3000 internally).
# Override if your laptop already has something on 3000.
WEBAPP_PORT=3000

# Hugging Face write token, used by data/ingest/push_to_huggingface.py.
# Only needed when re-publishing the dataset; ordinary users don't need this.
# Create at https://huggingface.co/settings/tokens (fine-grained, write scope
# scoped to the target dataset repo only).
HF_TOKEN=
